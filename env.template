# =============================================================================
# Azure AI Search
# =============================================================================
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_ADMIN_KEY=<your-search-admin-key>
AZURE_SEARCH_INDEX_NAME=faq-index

# =============================================================================
# Azure AI Foundry — embeddings
# =============================================================================
AZURE_AI_ENDPOINT=https://<your-project>.services.ai.azure.com
AZURE_AI_API_KEY=<your-api-key>
AZURE_AI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# =============================================================================
# Microsoft Graph — SharePoint access (App Registration with Sites.Read.All)
# =============================================================================
GRAPH_TENANT_ID=<your-tenant-id>
GRAPH_CLIENT_ID=<your-app-client-id>
GRAPH_CLIENT_SECRET=<your-app-client-secret>

# =============================================================================
# SharePoint site and list
# =============================================================================
SHAREPOINT_SITE_HOSTNAME=<your-tenant>.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/<your-site>
SHAREPOINT_LIST_NAME=FAQ List
